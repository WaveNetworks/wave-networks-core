# wave-networks-core .htaccess
# Security & Routing

# Custom error pages — logged to DB for security monitoring
ErrorDocument 403 /admin/error.php
ErrorDocument 404 /admin/error.php
ErrorDocument 500 /admin/error.php

# Deny direct web access to sensitive folders via rewrite
<IfModule mod_rewrite.c>
    RewriteEngine On

    # /admin/ directory index → redirect to login
    RewriteRule ^$ /admin/auth/login.php [R=302,L]

    # Block access to sensitive directories
    RewriteRule ^(vendor|db_migrations|cron|tests|include|config|views|snippets|docker)(/|$) - [F,L]

    # Serve branding assets from files directory via branding.php proxy
    RewriteRule ^branding/(.+)$ branding.php?f=$1 [L,QSA]

    # Pretty URLs (optional - index.php handles routing)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
</IfModule>

# Deny access to hidden files (.env, .git, etc.)
<FilesMatch "^\.">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# Deny access to composer files
<FilesMatch "^(composer\.(json|lock)|package\.json|package-lock\.json|deploy\.py|deploy_config\.py|deploy_config\.sample\.py|Dockerfile|docker-compose.*\.yml|CLAUDE\.md|CHILD_APP_SPEC\.md)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# Security headers
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
