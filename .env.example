# wave-networks-core environment template
# Used by Docker. On shared hosting use admin/config/config.php instead.

ENVIRONMENT=development

# Main Database
DB_HOST_MAIN=db
DB_NAME_MAIN=wncore_main
DB_USER=root
MYSQL_ROOT_PASSWORD=dev_root_password_123

# Shard Database
DB_HOST_SHARD=db_shard
DB_NAME_SHARD=wncore_shard_1

# File storage (Docker only - on server set $files_location in config file)
FILES_LOCATION=/var/files/

# Mail (Mailhog in dev)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@yourdomain.com
MAIL_FROM_NAME=Wave Networks

# Auth secrets - GENERATE REAL VALUES FOR PRODUCTION
APP_SECRET=change_this_to_a_64_char_random_string
HIDDEN_HASH=change_this_to_another_random_string

# OAuth Providers (leave blank to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# reCAPTCHA (leave blank to disable)
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Stripe
STRIPE_SECRET_KEY=sk_test_xxxx
STRIPE_PUBLIC_KEY=pk_test_xxxx

# Test data (development only)
SEED_TEST_DATA=true
